# Reproducible installs across the monorepo.
# Require the Node/pnpm versions declared in root package.json#engines.
engine-strict=true

# Auto-install peer dependencies (Next.js / React ecosystem relies on this).
auto-install-peers=true

# Hoist only strict peer deps; keep the dependency graph explicit per workspace.
strict-peer-dependencies=false

# Pin resolutions to exact versions when using `pnpm add`.
save-exact=true

# Use isolated node_modules so workspaces cannot access undeclared deps.
node-linker=isolated

# Shared lockfile at the repo root.
shared-workspace-lockfile=true
