{
  "name": "@certiq/api",
  "version": "0.0.0",
  "private": true,
  "description": "Certiq NestJS API. Scaffold-only for the landing page scope; exposes a health endpoint and is not consumed by apps/web.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1049.0",
    "@aws-sdk/s3-request-presigner": "3.1049.0",
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "10.4.4",
    "@nestjs/mongoose": "10.1.0",
    "@nestjs/platform-express": "10.4.4",
    "better-auth": "1.6.11",
    "dotenv": "17.4.2",
    "ioredis": "5.10.1",
    "mongodb": "6.12.0",
    "mongoose": "8.9.5",
    "multer": "2.1.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@certiq/eslint-config": "workspace:*",
    "@certiq/tsconfig": "workspace:*",
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "10.4.4",
    "@types/express": "4.17.21",
    "@types/multer": "2.1.0",
    "@types/node": "20.16.10",
    "@types/supertest": "6.0.2",
    "fast-check": "^3.22.0",
    "supertest": "7.0.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.6.2",
    "vitest": "2.1.2"
  }
}
