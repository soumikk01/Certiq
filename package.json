{
  "name": "certiq",
  "version": "0.0.0",
  "private": true,
  "description": "Certiq monorepo: Next.js landing page (apps/web), NestJS API (apps/api), and shared packages (ui, tsconfig, eslint-config).",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "turbo": "2.1.3",
    "typescript": "5.6.2"
  },
  "dependencies": {
    "pnpm": "11.1.1"
  }
}
